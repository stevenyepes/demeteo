{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "demeteo",
  "version": "0.1.0",
  "identifier": "com.jsteven.demeteo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "demeteo",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 700,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
